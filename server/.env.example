# ---- Server environment variables ----

# Local PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/job_tracker?schema=public"

# Port the Express server listens on.
PORT=5000

# Comma-separated list of allowed origins for CORS (frontend URL).
CORS_ORIGIN="http://localhost:3000"

# ---- Firebase Admin (Phase 2) ----
# Firebase Console > Project Settings > Service accounts > "Generate new private key".
# The downloaded JSON contains project_id, client_email, and private_key.
# Keep the private key on a single line and preserve the literal "\n" sequences.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Adzuna job board API (Phase 3) ----
# Sign up at https://developer.adzuna.com/ and create an app to get these.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Optional Adzuna country marketplace code (defaults to "us"). e.g. gb, ca, au.
# ADZUNA_COUNTRY=us

# ---- The following are placeholders for later phases (not used in Phase 1) ----

# AWS S3 (Phase 4)
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# OpenAI / AI provider (Phase 4)
# OPENAI_API_KEY=
