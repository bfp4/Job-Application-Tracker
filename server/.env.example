# ---- Server environment variables ----

# PostgreSQL connection string used by Prisma.
# Points at the AWS RDS PostgreSQL instance (Phase 5). Replace the placeholders
# with the master username, password, RDS endpoint and database name.
# Format: postgresql://<user>:<password>@<rds-endpoint>:5432/<dbname>
#
# NOTE: in production RDS is private (not reachable from the internet). For
# local prisma migrate/studio against prod, open the SSH tunnel first
# (see "Local dev against private RDS" in the README) and point this at
# localhost:5433 instead of the RDS endpoint.
DATABASE_URL="postgresql://<user>:<password>@<rds-endpoint>:5432/<dbname>"

# Port the Express server listens on.
PORT=5000

# Comma-separated list of allowed origins for CORS (frontend URL).
CORS_ORIGIN="http://localhost:3000"

# ---- Firebase Admin (Phase 2) ----
# Firebase Console > Project Settings > Service accounts > "Generate new private key".
# The downloaded JSON contains project_id, client_email, and private_key.
# Keep the private key on a single line and preserve the literal "\n" sequences.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- AWS S3 file uploads (Phase 5) ----
# Used to mint pre-signed URLs so the frontend can upload/download files directly.
# The access keys are for LOCAL DEV ONLY: on EC2 leave both unset and the SDK
# resolves credentials from the instance role instead (no static keys on the box).
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# ---- Anthropic Claude API (AI resume tips) ----
# Create a key at https://console.anthropic.com/ > API Keys.
# Used by the resume-tips agent to analyze the stored resume against a job
# posting and produce structured advice.
ANTHROPIC_API_KEY=
