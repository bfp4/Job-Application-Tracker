generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Field a user's tailored resume is specialized for. Drives the field-specific
// guidance in the tailored-resume generation prompt. KEEP IN SYNC with
// SPECIALIZATIONS in server/src/lib/resumeSpecializations.ts.
enum ResumeSpecialization {
  GENERAL
  SOFTWARE_ENGINEERING
  FINANCE
  CONSULTING
  MARKETING
  SALES
  HEALTHCARE
  DESIGN
  DATA_ANALYTICS
}

model User {
  id                   String               @id @default(cuid())
  firebaseUid          String               @unique
  email                String               @unique
  createdAt            DateTime             @default(now())
  // How the user wants their tailored resumes specialized (see enum above).
  resumeSpecialization ResumeSpecialization @default(GENERAL)
  baseResumes          BaseResume[]
  applications         Application[]
  jobPostings          JobPosting[]
}

model BaseResume {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  pdfS3Key         String
  markdownS3Key    String
  createdAt        DateTime          @default(now())
  resumeAnalyses   ResumeAnalysis[]
  tailoredResumes  TailoredResume[]

  @@index([userId])
}

model Company {
  id          String       @id @default(cuid())
  name        String       @unique
  website     String?
  jobPostings JobPosting[]
}

// Postings are scoped to the user who entered them — the same jobUrl entered
// by two users produces two independent rows, so no user can rewrite what
// another user sees.
model JobPosting {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  companyId    String?
  company      Company?      @relation(fields: [companyId], references: [id])
  title        String
  location     String[]      @default([])
  salary       String?
  jobUrl       String
  description  String?
  matchScore   Int?
  matchReasons String[]
  postedDate   DateTime?
  fetchedAt    DateTime      @default(now())
  applications Application[]

  @@unique([userId, jobUrl])
  @@index([userId])
}

enum ApplicationStatus {
  NOT_APPLIED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
}

model Application {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  jobPostingId String
  jobPosting   JobPosting        @relation(fields: [jobPostingId], references: [id])
  status       ApplicationStatus @default(NOT_APPLIED)
  notes        String?
  // Where the user found the job (LinkedIn, referral, ...). Free text.
  source       String?
  appliedDate  DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  followUps      FollowUp[]
  resumeAnalysis ResumeAnalysis?
  tailoredResume TailoredResume?
  questions      ApplicationQuestion[]
  contacts       Contact[]

  @@unique([userId, jobPostingId])
  @@index([userId])
  // The daily reminder Lambda scans for status = NOT_APPLIED across all users.
  @@index([status])
}

// Where the user is in the LinkedIn networking flow with a contact.
enum LinkedinStatus {
  NONE // No LinkedIn action taken yet.
  CONNECTION_SENT // Connection request sent, not yet accepted.
  CONNECTED // Connection accepted — now 1st-degree.
  MESSAGING // Actively exchanging messages.
}

// A person the user is in contact with about this application
// (recruiter, hiring manager, referral, ...).
model Contact {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name          String
  position      String?
  linkedinUrl   String?
  phone         String?
  email         String?
  notes         String?
  // Where the user stands in the LinkedIn networking flow with this person.
  linkedinStatus LinkedinStatus @default(NONE)
  // The last AI-drafted (and possibly hand-edited) LinkedIn connection note.
  // Capped at 300 chars to match LinkedIn's connection-request limit.
  connectMessage String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId])
}

// A question asked on the job application form (e.g. "What project are you
// most proud of?"), with the user's answer. The answer can be AI-drafted from
// the resume + posting and then edited by hand — the row doesn't distinguish.
model ApplicationQuestion {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  question      String
  answer        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId])
}

// One saved resume-tips analysis per application. baseResumeId and
// jobPostingHash record what the analysis was generated from, so a re-run is
// only allowed once the resume or the posting's content has actually changed.
model ResumeAnalysis {
  id             String      @id @default(cuid())
  applicationId  String      @unique
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  baseResumeId   String
  baseResume     BaseResume  @relation(fields: [baseResumeId], references: [id])
  jobPostingHash String
  content        Json
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// One saved tailored-resume draft per application, generated by rephrasing and
// reordering the base resume for this posting (never inventing facts).
// baseResumeId + jobPostingHash record what it was generated from — same
// staleness rule as ResumeAnalysis. `edited` flips true once the user hand-
// edits the draft, so a regenerate can warn before discarding their changes.
model TailoredResume {
  id             String      @id @default(cuid())
  applicationId  String      @unique
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  baseResumeId   String
  baseResume     BaseResume  @relation(fields: [baseResumeId], references: [id])
  jobPostingHash String
  content        Json
  edited         Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// NOTE: lambda/src/db.ts queries this model (and Application/User/JobPosting/
// Company) with raw SQL — renames here must be mirrored there by hand.
model FollowUp {
  id             String      @id @default(cuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  followUpDate   DateTime
  note           String?
  completed      Boolean     @default(false)
  // Last time the reminder Lambda mentioned this follow-up in a digest.
  // Dedupes within a day; the digest re-mentions it each day from 3 days
  // before the due date through the day itself.
  reminderSentAt DateTime?

  @@index([applicationId])
  // The daily reminder Lambda queries a 4-day followUpDate window across all
  // users; without this it sequential-scans the whole table.
  @@index([followUpDate])
}
