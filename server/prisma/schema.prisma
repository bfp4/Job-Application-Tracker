generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  firebaseUid  String        @unique
  email        String        @unique
  createdAt    DateTime      @default(now())
  baseResumes  BaseResume[]
  applications Application[]
  jobPostings  JobPosting[]
}

model BaseResume {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  pdfS3Key       String
  markdownS3Key  String
  createdAt      DateTime         @default(now())
  resumeAnalyses ResumeAnalysis[]

  @@index([userId])
}

model Company {
  id          String       @id @default(cuid())
  name        String       @unique
  website     String?
  jobPostings JobPosting[]
}

// Postings are scoped to the user who entered them — the same jobUrl entered
// by two users produces two independent rows, so no user can rewrite what
// another user sees.
model JobPosting {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  companyId    String?
  company      Company?      @relation(fields: [companyId], references: [id])
  title        String
  location     String[]      @default([])
  salary       String?
  jobUrl       String
  description  String?
  matchScore   Int?
  matchReasons String[]
  postedDate   DateTime?
  fetchedAt    DateTime      @default(now())
  applications Application[]

  @@unique([userId, jobUrl])
  @@index([userId])
}

enum ApplicationStatus {
  NOT_APPLIED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
}

model Application {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  jobPostingId String
  jobPosting   JobPosting        @relation(fields: [jobPostingId], references: [id])
  status       ApplicationStatus @default(NOT_APPLIED)
  notes        String?
  // Where the user found the job (LinkedIn, referral, ...). Free text.
  source       String?
  appliedDate  DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  followUps      FollowUp[]
  resumeAnalysis ResumeAnalysis?
  questions      ApplicationQuestion[]
  contacts       Contact[]

  @@unique([userId, jobPostingId])
  @@index([userId])
  // The daily reminder Lambda scans for status = NOT_APPLIED across all users.
  @@index([status])
}

enum ScrapedStatus {
  NOT_SCRAPED
  PENDING
  DONE
  FAILED
}

// A person the user is in contact with about this application
// (recruiter, hiring manager, referral, ...).
model Contact {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name          String
  position      String?
  linkedinUrl   String?
  phone         String?
  email         String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  scrapedStatus ScrapedStatus @default(NOT_SCRAPED)
  scrapedAt     DateTime? 

  @@index([applicationId])
}

// A question asked on the job application form (e.g. "What project are you
// most proud of?"), with the user's answer. The answer can be AI-drafted from
// the resume + posting and then edited by hand — the row doesn't distinguish.
model ApplicationQuestion {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  question      String
  answer        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId])
}

// One saved resume-tips analysis per application. baseResumeId and
// jobPostingHash record what the analysis was generated from, so a re-run is
// only allowed once the resume or the posting's content has actually changed.
model ResumeAnalysis {
  id             String      @id @default(cuid())
  applicationId  String      @unique
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  baseResumeId   String
  baseResume     BaseResume  @relation(fields: [baseResumeId], references: [id])
  jobPostingHash String
  content        Json
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// NOTE: lambda/src/db.ts queries this model (and Application/User/JobPosting/
// Company) with raw SQL — renames here must be mirrored there by hand.
model FollowUp {
  id             String      @id @default(cuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  followUpDate   DateTime
  note           String?
  completed      Boolean     @default(false)
  // Last time the reminder Lambda mentioned this follow-up in a digest.
  // Dedupes within a day; the digest re-mentions it each day from 3 days
  // before the due date through the day itself.
  reminderSentAt DateTime?

  @@index([applicationId])
  // The daily reminder Lambda queries a 4-day followUpDate window across all
  // users; without this it sequential-scans the whole table.
  @@index([followUpDate])
}
