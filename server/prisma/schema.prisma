generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  firebaseUid  String        @unique
  email        String        @unique
  createdAt    DateTime      @default(now())
  baseResumes  BaseResume[]
  searchRuns   SearchRun[]
  applications Application[]
}

model BaseResume {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  pdfS3Key   String
  parsed     Json
  createdAt  DateTime    @default(now())
  searchRuns SearchRun[]

  @@index([userId])
}

// A logged invocation of the merged strategy+search agent — since the search
// is a non-deterministic adaptive loop, this trace (not the prompt text) is
// what explains what a given run actually did.
model SearchRun {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  baseResumeId String
  baseResume   BaseResume @relation(fields: [baseResumeId], references: [id])
  runAt        DateTime   @default(now())
  resultCount  Int
  // The agent's stated plan before it began searching, if produced.
  plan         String?
  // Ordered list of server-tool calls (web_search/web_fetch queries and URLs) made during the run.
  trace        Json?

  @@index([userId])
}

model Company {
  id          String       @id @default(cuid())
  name        String       @unique
  website     String?
  jobPostings JobPosting[]
}

model JobPosting {
  id           String        @id @default(cuid())
  companyId    String?
  company      Company?      @relation(fields: [companyId], references: [id])
  title        String
  location     String?
  jobUrl       String        @unique
  description  String?
  matchScore   Int?
  matchReasons String[]
  postedDate   DateTime?
  fetchedAt    DateTime      @default(now())
  applications Application[]
}

enum ApplicationStatus {
  NOT_APPLIED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
}

model Application {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  jobPostingId String
  jobPosting   JobPosting        @relation(fields: [jobPostingId], references: [id])
  status       ApplicationStatus @default(NOT_APPLIED)
  notes        String?
  appliedDate  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  followUps    FollowUp[]

  @@unique([userId, jobPostingId])
  @@index([userId])
}

model FollowUp {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  followUpDate  DateTime
  note          String?
  completed     Boolean     @default(false)

  @@index([applicationId])
}
