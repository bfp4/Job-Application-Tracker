generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  firebaseUid  String        @unique
  email        String        @unique
  createdAt    DateTime      @default(now())
  baseResumes  BaseResume[]
  applications Application[]
  jobPostings  JobPosting[]
}

model BaseResume {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  pdfS3Key       String
  markdownS3Key  String
  createdAt      DateTime         @default(now())
  resumeAnalyses ResumeAnalysis[]

  @@index([userId])
}

model Company {
  id          String       @id @default(cuid())
  name        String       @unique
  website     String?
  jobPostings JobPosting[]
}

// Postings are scoped to the user who entered them — the same jobUrl entered
// by two users produces two independent rows, so no user can rewrite what
// another user sees.
model JobPosting {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  companyId    String?
  company      Company?      @relation(fields: [companyId], references: [id])
  title        String
  location     String[]      @default([])
  salary       String?
  jobUrl       String
  description  String?
  matchScore   Int?
  matchReasons String[]
  postedDate   DateTime?
  fetchedAt    DateTime      @default(now())
  applications Application[]

  @@unique([userId, jobUrl])
  @@index([userId])
}

enum ApplicationStatus {
  NOT_APPLIED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
}

model Application {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  jobPostingId String
  jobPosting   JobPosting        @relation(fields: [jobPostingId], references: [id])
  status       ApplicationStatus @default(NOT_APPLIED)
  notes        String?
  appliedDate  DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  followUps      FollowUp[]
  resumeAnalysis ResumeAnalysis?

  @@unique([userId, jobPostingId])
  @@index([userId])
}

// One saved resume-tips analysis per application. baseResumeId and
// jobPostingHash record what the analysis was generated from, so a re-run is
// only allowed once the resume or the posting's content has actually changed.
model ResumeAnalysis {
  id             String      @id @default(cuid())
  applicationId  String      @unique
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  baseResumeId   String
  baseResume     BaseResume  @relation(fields: [baseResumeId], references: [id])
  jobPostingHash String
  content        Json
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model FollowUp {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  followUpDate  DateTime
  note          String?
  completed     Boolean     @default(false)

  @@index([applicationId])
}
