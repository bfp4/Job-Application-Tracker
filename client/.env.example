# ---- Client environment variables ----

# Base URL of the backend API.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Email shown to trial-expired users so they can request full access.
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# ---- Firebase Web SDK (Phase 2) ----
# Firebase Console > Project Settings > General > "Your apps" > Web app > SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Google Maps Places (job location autocomplete) ----
# Google Cloud Console > APIs & Services > Credentials. Enable "Places API"
# and "Maps JavaScript API", then restrict the key to your site's HTTP
# referrers. Without this set, the location field falls back to plain
# free-text tag entry (no autocomplete).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
