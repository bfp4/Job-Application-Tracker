# ---- Daily digest Lambda environment variables ----

# PostgreSQL connection string used by Prisma (the same RDS database the server
# uses). Format: postgresql://<user>:<password>@<rds-endpoint>:5432/<dbname>
DATABASE_URL="postgresql://<user>:<password>@<rds-endpoint>:5432/<dbname>"

# AWS region for the SES client, e.g. us-east-2 (use the region code, NOT the
# human-readable name). SES must be set up in this region.
AWS_REGION=us-east-2

# IAM credentials with ses:SendEmail permission. Required for local test runs;
# in deployed Lambda these come from the function's execution role instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Verified SES sender ("From") address. In the SES sandbox, recipient addresses
# must also be verified.
SES_SENDER_EMAIL=

# ---- Adzuna job board API ----
# Reused by the shared job-source adapter to fetch fresh postings for the digest.
# Sign up at https://developer.adzuna.com/ and create an app to get these.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
