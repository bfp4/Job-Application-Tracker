# Production values uploaded to SSM Parameter Store by 04-ssm-params.sh.
# Copy to infra/prod.env (gitignored) and fill in. Same format as server/.env.
#
# Differences from local dev:
#  - CORS_ORIGIN must include the Vercel production URL.
#  - No AWS access keys: the EC2 instance role provides S3 credentials.
#  - No PORT: the API port (5000) is fixed infra — the Dockerfile, compose
#    healthcheck, and Caddyfile all assume it, so it is not configurable here.
DATABASE_URL="postgresql://<user>:<password>@<rds-endpoint>:5432/<dbname>"
CORS_ORIGIN="https://jobstrackeragent.vercel.app"
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
AWS_REGION=us-east-2
AWS_S3_BUCKET_NAME=job-tracker-files-ari
ANTHROPIC_API_KEY=
